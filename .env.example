# InvenTree API Configuration
# These use Nuxt runtime config naming so they can be overridden at runtime
# without rebuilding the app.

# Application Branding
# Override the app name and tagline displayed in the UI
NUXT_PUBLIC_APP_NAME=XTS Inventory
NUXT_PUBLIC_APP_TAGLINE=Quick and simple shop floor interface

# Local dev: http://localhost:8000/api
# Production: http://your-inventree-server:8000/api
NUXT_PUBLIC_INVENTREE_API_URL=http://localhost:8000/api

# Your InvenTree API token (generate in InvenTree: Settings > API Tokens)
NUXT_PUBLIC_INVENTREE_API_TOKEN=

# Set to 'true' for local development without InvenTree, 'false' for production
NUXT_PUBLIC_USE_MOCK_API=true

# Zebra Label Printer Configuration
# URL of the zebra-label-printer HTTP API (typically runs on port 3420)
NUXT_PUBLIC_ZEBRA_PRINTER_URL=http://localhost:3420

# API key for the zebra-label-printer service (if configured)
NUXT_PUBLIC_ZEBRA_API_KEY=
